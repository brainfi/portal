{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "paths": { "@/*": ["./src/*"] }
  },
  "include": [
    "src/**/*",
    "App.tsx",
    "main.tsx",
    "components/**/*",
    "pages/**/*",
    "contexts/**/*",
    "lib/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
